---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
  noIndex?: boolean;
  ogImage?: string;
}

const {
  title,
  description = "Run intelligent actions privately from your clipboard. Powered locally by your favorite model.",
  keywords = "local LLM, clipboard AI, privacy AI, offline AI assistant, Raycast extension, LM Studio, Ollama, local language model, clipboard assistant, Mac AI tool, AI text processing, clipboard automation, local LLM, AI shortcuts",
  noIndex = false,
  ogImage = "/images/social-media-sharing.png"
} = Astro.props;

const siteUrl = "https://getcai.app";
const fullOgImage = new URL(ogImage, siteUrl).toString();

// Structured data for rich snippets
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Cai",
  "applicationCategory": "ProductivityApplication",
  "operatingSystem": "macOS",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": description,
  "url": siteUrl,
  "image": fullOgImage,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "ratingCount": "1"
  },
  "featureList": [
    "Local AI processing",
    "Privacy-focused clipboard automation",
    "Smart text actions",
    "Custom AI commands",
    "Works with LM Studio, Ollama, and more"
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="Cai" />
    <meta name="theme-color" content="#A78BFA" />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:site_name" content="Cai: The Private Clipboard AI" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={siteUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={fullOgImage} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

    <!-- GoatCounter Analytics (Privacy-friendly, no cookies) -->
    <script data-goatcounter="https://cai.goatcounter.com/count" async src="//gc.zgo.at/count.js" is:inline></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=General+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --gradient-start: #A78BFA;
    --gradient-end: #F78595;
    --gradient-mid: #D380C3;

    --accent: #A78BFA;
    --accent-light: #C4B5FD;
    --accent-pink: #F78595;
    --grey: #2A2A2A;
    --grey-light: #6B6B6B;
    --white: #FFFFFF;
    --off-white: #FEFEFE;
    --bg-light: #FFFFFF;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: 'General Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    padding: 0;
    color: var(--grey);
    background: var(--bg-light);
    line-height: 1.65;
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', sans-serif;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  img, video {
    max-width: 100%;
    height: auto;
    display: block;
  }

  button {
    font-family: inherit;
    cursor: pointer;
    border: none;
  }

  /* Animated gradient mesh background */
  @keyframes gradient-shift {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @keyframes float-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scale-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes glow-pulse {
    0%, 100% {
      box-shadow: 0 0 20px rgba(167, 139, 250, 0.3);
    }
    50% {
      box-shadow: 0 0 40px rgba(247, 133, 149, 0.5);
    }
  }
</style>
