---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Imprint - Cai">
  <Navbar />
  <main class="legal-page">
    <div class="container">
      <h1 class="page-title">Imprint</h1>

      <section class="legal-section">
        <h2>Information pursuant to § 5 TMG</h2>
        <p>
          [Company Name]<br />
          [Street Address]<br />
          [Postal Code, City]<br />
          [Country]
        </p>
      </section>

      <section class="legal-section">
        <h2>Represented by</h2>
        <p>[Name of Representative]</p>
      </section>

      <section class="legal-section">
        <h2>Contact</h2>
        <p>
          Email: <a href="mailto:contact@example.com" class="link">contact@example.com</a><br />
          Website: <a href="https://example.com" class="link" target="_blank" rel="noopener noreferrer">https://example.com</a>
        </p>
      </section>

      <section class="legal-section">
        <h2>Responsible for content</h2>
        <p>
          [Name]<br />
          [Address]
        </p>
      </section>

      <section class="legal-section">
        <h2>Dispute resolution</h2>
        <p>
          The European Commission provides a platform for online dispute resolution (OS):
          <a href="https://ec.europa.eu/consumers/odr" class="link" target="_blank" rel="noopener noreferrer">https://ec.europa.eu/consumers/odr</a>
        </p>
        <p>
          We are not willing or obliged to participate in dispute resolution proceedings before a consumer arbitration board.
        </p>
      </section>

      <section class="legal-section">
        <h2>Liability for content</h2>
        <p>
          As a service provider, we are responsible for our own content on these pages in accordance with general legislation.
          However, we are not obliged to monitor transmitted or stored third-party information or to investigate circumstances
          that indicate illegal activity.
        </p>
      </section>
    </div>
  </main>
</Layout>

<style>
  .legal-page {
    min-height: 100vh;
    background: linear-gradient(180deg, #0A0A0A 0%, #111111 100%);
    padding: 10rem 0 6rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .legal-section {
    margin-bottom: 3rem;
  }

  .legal-section h2 {
    font-size: 1.5rem;
    color: #FFFFFF;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .legal-section p {
    color: #B0B0B0;
    line-height: 1.8;
    margin-bottom: 1rem;
    font-size: 1.05rem;
  }

  .link {
    color: var(--accent-light);
    text-decoration: underline;
    transition: color 0.3s ease;
  }

  .link:hover {
    color: var(--accent-pink);
  }

  @media (max-width: 768px) {
    .legal-page {
      padding: 7rem 0 4rem;
    }

    .page-title {
      margin-bottom: 2rem;
    }

    .legal-section {
      margin-bottom: 2rem;
    }

    .legal-section h2 {
      font-size: 1.25rem;
    }

    .legal-section p {
      font-size: 1rem;
    }
  }
</style>
