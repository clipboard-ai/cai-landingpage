---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ComparisonPage from '../../components/ComparisonPage.astro';
import Footer from '../../components/Footer.astro';

const data = {
  competitor: {
    name: "ChatGPT",
    url: "https://chatgpt.com"
  },
  tldr: "ChatGPT is a cloud AI chat app, great for deep conversations, research, and complex reasoning. For quick text actions, you switch apps and paste text in. Cai runs actions directly on your selected text, locally on your Mac, without leaving your workflow.",
  features: [
    { name: "Works inline on selected text (no app switch)", cai: true, competitor: false },
    { name: "100% local, private by default", cai: true, competitor: false },
    { name: "Free and open source (MIT)", cai: true, competitor: "Free tier (limited)" },
    { name: "No account required", cai: true, competitor: false },
    { name: "Shell command execution", cai: true, competitor: false },
    { name: "GitHub & Linear integration", cai: true, competitor: false },
    { name: "Apple Intelligence support", cai: true, competitor: false },
    { name: "OCR / Image to text on selection", cai: true, competitor: false },
    { name: "Long-form multi-turn chat", cai: "Basic (Tab follow-up)", competitor: true },
    { name: "Web search / research mode", cai: false, competitor: true },
    { name: "Image generation", cai: false, competitor: true },
  ],
  whenCompetitor: {
    heading: "When to use ChatGPT",
    points: [
      "You need long-form multi-turn conversations and deep reasoning",
      "You want image generation, web search, or deep research mode",
      "You're working on tasks that require back-and-forth iteration with a cloud model",
      "Privacy is not a hard requirement for what you're working on",
    ]
  },
  whenCai: {
    heading: "When to use Cai",
    points: [
      "You want AI actions on selected text without switching apps or typing a prompt",
      "Privacy matters: your text stays on your Mac by default",
      "You need quick actions like summarize, translate, reply, create a GitHub or Linear ticket",
      "You want a free, open-source tool with no subscription and no account",
    ]
  },
  relatedComparisons: [
    { name: "Raycast", slug: "raycast" },
    { name: "BoltAI", slug: "boltai" },
    { name: "Alter", slug: "alter" },
  ]
};
---

<Layout
  title="Cai vs ChatGPT | Local AI Actions for Mac"
  description="Compare Cai and ChatGPT for macOS. Cai works inline on any selected text, runs locally by default, and is free and open source. No app switching, no subscription, no account."
  keywords="cai vs chatgpt, chatgpt alternative mac, local ai mac, ai actions macos, chatgpt desktop alternative, private ai mac"
>
  <Navbar />
  <ComparisonPage {...data} />
  <Footer />
</Layout>
