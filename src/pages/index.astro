---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import NewsletterCallout from '../components/NewsletterCallout.astro';
import FeatureCards from '../components/FeatureCards.astro';
import WorksEverywhere from '../components/WorksEverywhere.astro';
import LLMProviders from '../components/LLMProviders.astro';
import DemoSection from '../components/DemoSection.astro';
import FeatureBento from '../components/FeatureBento.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const quickActions = [
  { name: "Ask AI", description: "Run any prompt on your selected text", highlight: true },
  { name: "Reply", description: "Context-aware reply for emails, messages, and more", highlight: true },
  { name: "Image to Text (OCR)", description: "Extract text from images and screenshots", highlight: true },
  { name: "Create GitHub Issue", description: "Turn errors and text into GitHub issues with AI-generated titles", highlight: true },
  { name: "Create Linear Ticket", description: "File tickets from any app — terminal, browser, Slack", highlight: true },
  { name: "Create Calendar Event", description: "Create calendar event from text" },
  { name: "Summarize", description: "Create a concise summary" },
  { name: "Fix Grammar", description: "Fix grammar, spelling, and punctuation" },
  { name: "Translate", description: "Translate text to another language" },
  { name: "...", description: "And more" },
];

const customFeatures = [
  { name: "Custom Prompts", description: "Save AI prompts and shell commands for one-tap access", highlight: true },
  { name: "URL Actions", description: "Search Google Drive, Jira, Stack Overflow — any URL with %s becomes an action", highlight: true },
  { name: "Shell Commands", description: "Run scripts and CLI tools on your selected text", highlight: true },
  { name: "Custom Destinations", description: "Route results to Slack, Notion, or any app via webhooks, deeplinks, and AppleScript", highlight: true },
  { name: "GitHub & Linear", description: "Create issues and tickets with AI-generated context", highlight: true },
  { name: "Community Extensions", description: "Browse and install actions shared by others", secondary: true },
  { name: "Keyboard-First", description: "Type to filter, ⌘1–9 to execute — no mouse needed", secondary: true },
];
---

<Layout title="Cai: AI Action Layer for macOS | Free & Open Source">
  <Navbar />
  <Hero />

  <!-- Definition paragraph for AI citability and SEO -->
  <section class="definition">
    <div class="definition-container">
      <p class="definition-text">
        <strong>Cai</strong> is a free, open-source AI action layer for macOS. It lives in your menu bar and lets you select any text or image, press <kbd>⌥C</kbd>, and instantly run custom actions — AI prompts, shell commands, URL shortcuts, summaries, translations, OCR, GitHub issues, Linear tickets, and more. Save any shell command or script as a one-click action and run it on your selected text or on its own. It runs locally by default with a built-in AI engine, supports Apple Intelligence on macOS 26+, and connects to providers like LM Studio, Ollama, and cloud APIs. Cloud optional.
      </p>
    </div>
  </section>

  <FeatureCards />

  <!-- Demo Section 1: Run quick actions -->
  <DemoSection
    id="quick-actions"
    title='<span class="highlight">Smart actions</span>, ready-to-use.'
    subtitle="Cai detects what you selected — meetings, addresses, code, images — and shows the right actions automatically."
    actions={quickActions}
    mediaType="video"
    mediaSrc="/videos/cai-builtin-actions.mp4"
    posterSrc="/videos/cai-builtin-actions-poster.webp"
    mediaAlt="Run quick actions demo"
    backgroundColor="#111111"
  />

  <!-- Demo Section 2: Custom commands & actions -->
  <DemoSection
    id="custom-commands"
    title='Make it <span class="highlight">yours</span>'
    subtitle="Build your own actions with custom prompts, shell scripts, URL searches and route results anywhere."
    actions={customFeatures}
    mediaType="video"
    mediaSrc="/videos/cai-custom-actions.mp4"
    posterSrc="/videos/cai-custom-actions-poster.webp"
    mediaAlt="Custom commands and actions demo"
    backgroundColor="#0F0F0F"
    linkHref="https://github.com/cai-layer/cai-extensions"
    linkText="Browse community extensions →"
  />

  <!-- Shell callout -->
  <section class="shell-callout">
    <div class="shell-container">      
      <p class="shell-eyebrow">If it runs in <span class="highlight">Terminal</span>, it runs in Cai.</p>
      <div class="shell-commands">
        <code class="shell-code">$ lsof -ti :<span class="shell-var">{'{{selected text}}'}</span> | xargs kill -9</code>
        <code class="shell-code">$ gh pr list --search "<span class="shell-var">{'{{selected text}}'}</span>"</code>
        <code class="shell-code">$ echo -n '<span class="shell-var">{'{{selected text}}'}</span>' | base64</code>
      </div>
      <p class="shell-desc">Save shell commands as custom actions and fire them anywhere. <br/> Use your selected text, screenshots or fixed commands.</p>
    </div>
  </section>

  <FeatureBento />
  <LLMProviders />
  <WorksEverywhere />
  <FAQ />
  <NewsletterCallout />
  <Footer />
</Layout>

<style>
  .definition {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .definition-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .definition-text {
    color: #808080;
    font-size: 0.92rem;
    line-height: 1.75;
    text-align: center;
  }

  .definition-text strong {
    color: #B0B0B0;
    font-weight: 600;
  }

  .definition-text kbd {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85em;
  }

  /* Shell callout */
  .shell-callout {
    background: #111111;
    padding: 3rem 0 5rem;
    text-align: center;
  }

  .shell-container {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .shell-eyebrow {
    letter-spacing: 0.06em;
    font-size: 0.88rem;
    font-weight: 600;
    color: #808080;
    margin: 0 0 1.5rem;
  }

  .shell-eyebrow :global(.highlight) {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .shell-commands {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0;
  }

  .shell-code {
    display: inline-block;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85rem;
    color: #C0C0C0;
    padding: 0.6rem 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 8px;
  }

  .shell-var {
    color: #A78BFA;
  }

  .shell-desc {
    color: #707070;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 1.5rem auto 0;
    max-width: 520px;
  }

  @media (max-width: 640px) {
    .shell-callout {
      padding: 3.5rem 0;
    }

    .shell-code {
      font-size: 0.75rem;
      overflow-x: auto;
    }
  }

  @media (max-width: 768px) {
    .definition {
      padding: 0 0 1.5rem;
    }

    .definition-text {
      font-size: 0.88rem;
    }
  }
</style>
