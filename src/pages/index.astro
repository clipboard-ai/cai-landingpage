---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import FeatureCards from '../components/FeatureCards.astro';
import WorksEverywhere from '../components/WorksEverywhere.astro';
import LLMProviders from '../components/LLMProviders.astro';
import DemoSection from '../components/DemoSection.astro';
import FeatureBento from '../components/FeatureBento.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const quickActions = [
  { name: "Explain", description: "Get a clear explanation of selected text" },
  { name: "Reply", description: "Context-aware reply for emails, messages, and more" },
  { name: "Summarize", description: "Create a concise summary" },
  { name: "Define", description: "Define a word" },
  { name: "Translate", description: "Translate text to another language" },
  { name: "Open in Maps", description: "Open address in Maps app" },
  { name: "Create Calendar Event", description: "Create calendar event from text" },
  { name: "Beautify JSON", description: "Format and beautify JSON data" },  // { name: "Code", description: "Explain a code snippets" },
  { name: "Search the Web", description: "Search something on the web" },
  { name: "Custom Action", description: "Execute a custom prompt" },
];

const customFeatures = [
  { name: "On-the-fly Prompts", description: "Run any AI instruction against your clipboard text", highlight: true },
  { name: "Saved Prompt Shortcuts", description: "Save prompts you use often for one-tap access", highlight: true },
  { name: "URL Shortcuts", description: "Create URL templates with %s — search Reddit, Google Translate, Wikipedia, and more", highlight: true },
  { name: "Custom Destinations", description: "Send results to Slack, Bear, Notion, or any app via webhooks, AppleScript, URL schemes, and shell commands", highlight: true },
  { name: "Type to Filter", description: "Just start typing to find your shortcuts instantly", secondary: true },
  { name: "⌘1–9 to Execute", description: "Launch any shortcut by number, no mouse needed", secondary: true },
];
---

<Layout title="Cai: The Private Clipboard AI">
  <Navbar />
  <Hero />
  <FeatureCards />
  <WorksEverywhere />
  <LLMProviders />

  <!-- Demo Section 1: Run quick actions -->
  <DemoSection
    id="quick-actions"
    title='<span class="highlight">Smart actions</span>, ready-to-use.'
    subtitle="Cai instantly identifies text types—like meetings, addresses, JSON, or code—and suggests the best actions for your selection."
    actions={quickActions}
    mediaType="video"
    mediaSrc="/videos/cai-builtin-actions.mp4"
    posterSrc="/videos/cai-builtin-actions-poster.webp"
    mediaAlt="Run quick actions demo"
    backgroundColor="#111111"
  />

  <!-- Demo Section 2: Custom commands & shortcuts -->
  <DemoSection
    id="custom-commands"
    title='Make it <span class="highlight">yours</span>'
    subtitle="Run on-the-fly AI prompts, or save your own shortcuts for prompts and URLs."
    actions={customFeatures}
    mediaType="video"
    mediaSrc="/videos/cai-custom-actions.mp4"
    posterSrc="/videos/cai-custom-actions-poster.webp"
    mediaAlt="Custom commands and shortcuts demo"
    backgroundColor="#0F0F0F"
  />
  
  <FeatureBento />
  <FAQ />
  <Footer />
</Layout>
