---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import NewsletterCallout from '../components/NewsletterCallout.astro';
import FeatureCards from '../components/FeatureCards.astro';
import WorksEverywhere from '../components/WorksEverywhere.astro';
import LLMProviders from '../components/LLMProviders.astro';
import DemoSection from '../components/DemoSection.astro';
import FeatureBento from '../components/FeatureBento.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const quickActions = [
  { name: "Ask AI", description: "Run any prompt on your selected text", highlight: true },
  { name: "Reply", description: "Context-aware reply for email or chat", highlight: true },
  { name: "Image to Text (OCR)", description: "Extract text from images and screenshots", highlight: true },
  { name: "Create GitHub Issue", description: "Turn errors and text into GitHub issues with AI-generated titles", highlight: true },
  { name: "Create Linear Ticket", description: "File tickets from any app: terminal, browser, Slack", highlight: true },
  { name: "Create Calendar Event", description: "Create calendar event from text" },
  { name: "Summarize", description: "Create a concise summary" },
  { name: "Fix Grammar", description: "Fix grammar, spelling, and punctuation" },
  { name: "Translate", description: "Translate text to another language" },
  { name: "...", description: "And more" },
];

const customFeatures = [
  { name: "Custom Prompts", description: "Save AI prompts and shell commands for one-tap access", highlight: true },
  { name: "URL Actions", description: "Search Google Drive, Jira, Stack Overflow; any URL with %s becomes an action", highlight: true },
  { name: "Shell Commands", description: "Run scripts and CLI tools on your selected text", highlight: true },
  { name: "Custom Destinations", description: "Route results to Slack, Notion, or any app via webhooks, deeplinks, and AppleScript", highlight: true },
  { name: "Community Extensions", description: "Browse and install actions shared by others", secondary: true },
  { name: "Keyboard-First", description: "Type to filter, ⌘1–9 to run. No mouse needed.", secondary: true },
];
---

<Layout title="Cai: AI Action Layer for macOS | Free & Open Source">
  <Navbar />
  <Hero />

  <!-- Definition paragraph for AI citability and SEO -->
  <section class="definition">
    <div class="definition-container">
      <p class="definition-text">
        <strong>Cai</strong> is a free, open-source AI action layer for macOS. It lives in your menu bar and lets you select any text or image, press <kbd>⌥C</kbd>, and instantly run custom actions: AI prompts, shell commands, URL shortcuts, summaries, translations, OCR, GitHub issues, Linear tickets. Save any shell command or script as a one-click action and run it on your selected text or on its own. It runs locally by default with a built-in AI engine, supports Apple Intelligence on macOS 26+, and connects to providers like LM Studio, Ollama, and cloud APIs. Cloud optional.
      </p>
    </div>
  </section>

  <FeatureCards />

  <!-- Demo Section 1: Run quick actions -->
  <DemoSection
    id="quick-actions"
    title='<span class="highlight">Smart actions</span>, ready-to-use.'
    subtitle="Cai reads what you selected (meetings, addresses, code, images) and surfaces the right actions automatically."
    actions={quickActions}
    mediaType="video"
    mediaSrc="/videos/cai-builtin-actions.mp4"
    posterSrc="/videos/cai-builtin-actions-poster.webp"
    mediaAlt="Run quick actions demo"
    backgroundColor="#111111"
  />

  <!-- Demo Section 2: Custom commands & actions -->
  <DemoSection
    id="custom-commands"
    title='Make it <span class="highlight">yours</span>'
    subtitle="Build your own actions with custom prompts, shell scripts, URL searches. Route results anywhere."
    actions={customFeatures}
    mediaType="video"
    mediaSrc="/videos/cai-custom-actions.mp4"
    posterSrc="/videos/cai-custom-actions-poster.webp"
    mediaAlt="Custom commands and actions demo"
    backgroundColor="#0F0F0F"
    linkHref="https://github.com/cai-layer/cai-extensions"
    linkText="Browse community extensions →"
  />

  <!-- Your own action library -->
  <section class="library-section" id="library">
    <div class="library-container">
      <p class="library-eyebrow">Your own action library</p>
      <h2 class="library-title">Type it once. <span class="highlight">Run it forever.</span></h2>
      <p class="library-subtitle">
        Save any AI prompt, shell script, or URL shortcut as a one-keystroke action. Your library grows with you.
      </p>

      <div class="terminal-window">
        <div class="terminal-chrome">
          <span class="terminal-dot dot-red"></span>
          <span class="terminal-dot dot-yellow"></span>
          <span class="terminal-dot dot-green"></span>
          <span class="terminal-label">cai — shell action</span>
        </div>
        <div class="terminal-body">
          <code class="terminal-line">$ lsof -ti :<span class="terminal-var">{'{{selected text}}'}</span> | xargs kill -9</code>
          <code class="terminal-line">$ gh pr list --search "<span class="terminal-var">{'{{selected text}}'}</span>"</code>
        </div>
      </div>

      <div class="terminal-window">
        <div class="terminal-chrome">
          <span class="terminal-dot dot-red"></span>
          <span class="terminal-dot dot-yellow"></span>
          <span class="terminal-dot dot-green"></span>
          <span class="terminal-label">cai — prompt action</span>
        </div>
        <div class="terminal-body">
          <code class="terminal-line"><span class="terminal-prefix">✦</span> Translate to a git command: <span class="terminal-var">{'{{selected text}}'}</span></code>
          <code class="terminal-line terminal-example"><span class="terminal-arrow">→</span> "undo last 2 commits" <span class="terminal-arrow">→</span> <span class="terminal-result">git reset --soft HEAD~2</span></code>
        </div>
      </div>

      <p class="library-caption">If it runs in Terminal or as a prompt, it runs in Cai.</p>
    </div>
  </section>

  <FeatureBento />
  <LLMProviders />
  <WorksEverywhere />
  <FAQ />
  <NewsletterCallout />
  <Footer />
</Layout>

<style>
  .definition {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .definition-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .definition-text {
    color: #808080;
    font-size: 0.92rem;
    line-height: 1.75;
    text-align: center;
  }

  .definition-text strong {
    color: #B0B0B0;
    font-weight: 600;
  }

  .definition-text kbd {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85em;
  }

  /* Your own action library section */
  .library-section {
    background: #0F0F0F;
    padding: 7rem 0;
    text-align: center;
  }

  .library-container {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .library-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    font-weight: 600;
    color: #808080;
    margin: 0 0 1rem;
  }

  .library-title {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    margin: 0 0 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .library-title :global(.highlight) {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .library-subtitle {
    color: #909090;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 580px;
    margin: 0 auto 3rem;
    line-height: 1.65;
  }

  .terminal-window {
    max-width: 620px;
    margin: 0 auto 2rem;
    background: #0A0A0A;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 8px 20px rgba(0, 0, 0, 0.3);
    text-align: left;
  }

  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.7rem 1rem;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    position: relative;
  }

  .terminal-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }

  .dot-red { background: #FF5F56; }
  .dot-yellow { background: #FFBD2E; }
  .dot-green { background: #27C93F; }

  .terminal-label {
    position: absolute;
    left: 0;
    right: 0;
    text-align: center;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    color: #707070;
    pointer-events: none;
  }

  .terminal-body {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .terminal-line {
    display: block;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9rem;
    color: #C0C0C0;
    white-space: pre;
    overflow-x: auto;
  }

  .terminal-var {
    color: #A78BFA;
  }

  .terminal-prefix {
    color: #A78BFA;
    margin-right: 0.35rem;
  }

  .terminal-example {
    color: #707070;
    font-size: 0.82rem;
    padding-left: 1.1rem;
  }

  .terminal-arrow {
    color: #505050;
    margin: 0 0.35rem;
  }

  .terminal-result {
    color: #8EC07C;
  }

  .library-caption {
    color: #707070;
    font-size: 0.95rem;
    font-style: italic;
    margin: 0;
  }

  @media (max-width: 640px) {
    .library-section {
      padding: 5rem 0;
    }

    .terminal-line {
      font-size: 0.78rem;
    }

    .terminal-label {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .definition {
      padding: 0 0 1.5rem;
    }

    .definition-text {
      font-size: 0.88rem;
    }
  }
</style>
