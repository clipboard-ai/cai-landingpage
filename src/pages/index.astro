---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import FeatureCards from '../components/FeatureCards.astro';
import WorksEverywhere from '../components/WorksEverywhere.astro';
import LLMProviders from '../components/LLMProviders.astro';
import DemoSection from '../components/DemoSection.astro';
import FeatureBento from '../components/FeatureBento.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const quickActions = [
  { name: "Ask AI", description: "Run any prompt on your clipboard content", highlight: true },
  { name: "Reply", description: "Context-aware reply for emails, messages, and more", highlight: true },
  { name: "Image to Text (OCR)", description: "Extract text from images and screenshots", highlight: true },
  { name: "Create Calendar Event", description: "Create calendar event from text", highlight: true },
  { name: "Run Shell Command", description: "Execute shell commands from your clipboard", highlight: true },
  { name: "Summarize", description: "Create a concise summary" },
  { name: "Fix Grammar", description: "Fix grammar, spelling, and punctuation" },
  { name: "Translate", description: "Translate text to another language" },
  { name: "...", description: "And more" },
];

const customFeatures = [
  { name: "Ask AI", description: "Run any AI instruction against your clipboard text", highlight: true },
  { name: "Saved Actions", description: "Save prompts and URL actions you use often for one-tap access", highlight: true },
  { name: "Web Search Actions", description: "Create URL templates with %s — search Reddit, Google Translate, Wikipedia, and more", highlight: true },
  { name: "Send Anywhere", description: "Route results to Slack, Bear, Notion, or any app via webhooks, deeplinks, AppleScript, and shell commands", highlight: true },
  { name: "Type to Filter", description: "Just start typing to find your actions instantly", secondary: true },
  { name: "⌘1–9 to Execute", description: "Launch any action by number, no mouse needed", secondary: true },
];
---

<Layout title="Cai: The Private Clipboard AI for Mac | Local, Free & Open Source">
  <Navbar />
  <Hero />
  <FeatureCards />

  <!-- Demo Section 1: Run quick actions -->
  <DemoSection
    id="quick-actions"
    title='<span class="highlight">Smart actions</span>, ready-to-use.'
    subtitle="Cai detects what you selected — meetings, addresses, code, images — and shows the right actions automatically."
    actions={quickActions}
    mediaType="video"
    mediaSrc="/videos/cai-builtin-actions.mp4"
    posterSrc="/videos/cai-builtin-actions-poster.webp"
    mediaAlt="Run quick actions demo"
    backgroundColor="#111111"
  />

  <WorksEverywhere />

  <!-- Demo Section 2: Custom commands & actions -->
  <DemoSection
    id="custom-commands"
    title='Make it <span class="highlight">yours</span>'
    subtitle="Run on-the-fly AI prompts, execute shell commands, save your own actions, and create custom destinations."
    actions={customFeatures}
    mediaType="video"
    mediaSrc="/videos/cai-custom-actions.mp4"
    posterSrc="/videos/cai-custom-actions-poster.webp"
    mediaAlt="Custom commands and actions demo"
    backgroundColor="#0F0F0F"
    linkHref="https://github.com/clipboard-ai/cai-extensions"
    linkText="Browse community extensions →"
  />

  <FeatureBento />
  <LLMProviders />
  <FAQ />
  <Footer />
</Layout>
