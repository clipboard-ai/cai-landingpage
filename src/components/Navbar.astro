---
import githubLogo from '../assets/images/GitHub_Invertocat_White.svg';
import caiLogoWhite from '../assets/images/cai-logo-fill-white.svg';
---

<nav class="navbar">
  <div class="container">
    <a href="/" class="logo">
      <img src={caiLogoWhite.src} alt="Cai" class="logo-image" />
    </a>

    <div class="nav-menu">
      <a href="#how-it-works" class="nav-link">How it works</a>
      <a href="#quick-actions" class="nav-link">Features</a>
      <a href="/docs/" class="nav-link">Docs</a>
      <a href="https://github.com/cai-layer/cai-extensions" class="nav-link" target="_blank" rel="noopener noreferrer">Extensions</a>
    </div>

    <div class="nav-actions">
      <a href="https://github.com/cai-layer/cai/releases/download/v1.2.1/Cai-1.2.1-macos.dmg" class="download-button" target="_blank" rel="noopener noreferrer">
        <svg class="apple-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" fill="currentColor"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
        <span>Download</span>
      </a>
      <a href="https://github.com/cai-layer/cai" class="github-button" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub">
        <img src={githubLogo.src} alt="GitHub" class="github-icon" />
      </a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 3rem);
    max-width: 1200px;
    padding: 0.75rem 1.5rem;
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(20px) saturate(180%);
    z-index: 100;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .container {
    max-width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--accent-light);
  }

  .logo {
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
  }

  .logo-image {
    height: 32px;
    width: auto;
  }

  .logo:hover {
    transform: scale(1.05);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .download-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #FFFFFF;
    color: #1A1A1A;
    padding: 0.6rem 1.1rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.85rem;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    white-space: nowrap;
  }

  .download-button:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
    background: #F5F5F5;
  }

  .apple-icon {
    width: 14px;
    height: 14px;
  }

  .github-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    padding: 0.85rem 0.95rem;
    border-radius: 12px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
  }

  .github-button:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
    background: rgba(255, 255, 255, 0.15);
  }

  .github-icon {
    width: 22px;
    height: 22px;
    object-fit: contain;
  }

  @media (max-width: 968px) {
    .nav-menu {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .navbar {
      top: 0.5rem;
      width: calc(100% - 1.5rem);
      padding: 0.6rem 1rem;
    }

    .logo-image {
      height: 28px;
    }

    .github-icon {
      width: 20px;
      height: 20px;
    }

    .download-button {
      padding: 0.5rem 0.9rem;
      font-size: 0.8rem;
    }

    .apple-icon {
      width: 12px;
      height: 12px;
    }

    .container {
      gap: 1.5rem;
    }
  }
</style>
