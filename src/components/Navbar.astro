---
import githubLogo from '../assets/images/GitHub_Invertocat_White.svg';
import raycastLogo from '../assets/images/logo-raycast.png';
import caiLogoWhite from '../assets/images/cai-logo-fill-white.svg';
---

<nav class="navbar">
  <div class="container">
    <a href="/" class="logo">
      <img src={caiLogoWhite.src} alt="Cai" class="logo-image" />
    </a>

    <div class="nav-menu">
      <a href="#how-it-works" class="nav-link">How it works</a>
      <a href="#quick-actions" class="nav-link">Features</a>
      <a href="https://www.raycast.com/store" class="nav-link" target="_blank" rel="noopener noreferrer">Raycast Store</a>
      <a href="https://github.com/soyasis/cai-clipboard-ai#-installation" class="nav-link" target="_blank" rel="noopener noreferrer">Get Started</a>
    </div>

    <div class="nav-actions">
      <a href="https://www.raycast.com/store" class="raycast-button" target="_blank" rel="noopener noreferrer" aria-label="Download from Raycast">
        <img src={raycastLogo.src} alt="Raycast" class="raycast-icon" />
      </a>
      <a href="https://github.com/soyasis/cai-clipboard-ai" class="github-button" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub">
        <img src={githubLogo.src} alt="GitHub" class="github-icon" />
      </a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 3rem);
    max-width: 1200px;
    padding: 0.75rem 1.5rem;
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(20px) saturate(180%);
    z-index: 100;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .container {
    max-width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--accent-light);
  }

  .logo {
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
  }

  .logo-image {
    height: 32px;
    width: auto;
  }

  .logo:hover {
    transform: scale(1.05);
  }

  .raycast-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    padding: 0.85rem 0.95rem;
    border-radius: 12px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
  }

  .raycast-button:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
    background: rgba(255, 255, 255, 0.15);
  }

  .raycast-icon {
    width: 22px;
    height: 22px;
    object-fit: contain;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .github-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    padding: 0.85rem 0.95rem;
    border-radius: 12px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
  }

  .github-button:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
    background: rgba(255, 255, 255, 0.15);
  }

  .github-icon {
    width: 22px;
    height: 22px;
    object-fit: contain;
  }

  @media (max-width: 968px) {
    .nav-menu {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .navbar {
      top: 0.5rem;
      width: calc(100% - 1.5rem);
      padding: 0.6rem 1rem;
    }

    .logo-image {
      height: 28px;
    }

    .raycast-icon,
    .github-icon {
      width: 20px;
      height: 20px;
    }

    .container {
      gap: 1.5rem;
    }
  }
</style>
