---
const features = [
  {
    number: "01",
    title: "Highlight",
    descriptionBold: "Select text in any app.",
    descriptionDetail: "Whether it's an email, a block of code, or an appointment, just highlight what you need."
  },
  {
    number: "02",
    title: "Trigger",
    descriptionBold: "Press ⌥C to summon Cai.",
    descriptionDetail: "The action menu appears instantly. No tabs, no waiting, no distractions."
  },
  {
    number: "03",
    title: "Transform",
    descriptionBold: "Execute and done.",
    descriptionDetail: "Choose a smart action, run a custom prompt, or use your saved shortcuts."
  }
];
---

<section class="features" id="how-it-works">
  <div class="container">
    <h2 class="section-title">Your local intelligence, <span class="highlight">one shortcut</span> away</h2>
    <p class="section-subtitle">
      Three steps. One shortcut. Zero app switching.
    </p>

    <div class="feature-grid">
      {features.map((feature, index) => (
        <>
          <div class="feature-card" style={`animation-delay: ${index * 0.15}s`}>
            <div class="feature-number">{feature.number}</div>
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-description">
              <strong>{feature.descriptionBold}</strong>
              {feature.descriptionDetail}
            </p>
          </div>
          {index < features.length - 1 && (
            <div class="flow-arrow" style={`animation-delay: ${index * 0.15 + 0.3}s`}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
              </svg>
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 7rem 0;
    background: linear-gradient(to bottom, #111111 0%, #0F0F0F 100%);
    position: relative;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    text-align: center;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    text-align: center;
    color: #909090;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 620px;
    margin: 0 auto 5rem;
    line-height: 1.65;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .flow-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(167, 139, 250, 0.3);
    animation: float-up 0.6s ease-out both;
  }

  .flow-arrow svg {
    width: 28px;
    height: 28px;
  }

  .feature-card {
    text-align: center;
    padding: 3rem 2rem;
    background: rgba(25, 25, 25, 0.8);
    border-radius: 24px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: float-up 0.6s ease-out both;
    border: 2px solid rgba(167, 139, 250, 0.1);
  }

  .feature-card:hover {
    transform: translateY(-12px) scale(1.03);
    box-shadow: 0 20px 50px rgba(211, 128, 195, 0.3);
    border-color: var(--accent-pink);
    background: rgba(30, 30, 30, 0.9);
  }

  .feature-number {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 800;
    margin: 0 auto 1.75rem;
    font-family: 'Outfit', sans-serif;
    box-shadow: 0 8px 20px rgba(167, 139, 250, 0.3);
    transition: all 0.3s ease;
  }

  .feature-card:hover .feature-number {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 12px 30px rgba(247, 133, 149, 0.4);
  }

  .feature-title {
    font-size: 1.65rem;
    color: #FFFFFF;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .feature-description {
    color: #A0A0A0;
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .feature-description strong {
    display: block;
    color: #D0D0D0;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 900px) {
    .feature-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .flow-arrow {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .features {
      padding: 5rem 0;
    }

    .feature-card {
      padding: 2.5rem 1.75rem;
    }

    .feature-number {
      width: 64px;
      height: 64px;
      font-size: 1.25rem;
    }
  }
</style>
