<section class="newsletter-callout" id="newsletter">
  <div class="container">
    <p class="eyebrow">Join the early crew</p>
    <p class="subtitle">Get v1.5 updates and first invite when we open a <span class="highlight">Discord</span>.

    <!-- MailerLite newsletter form. IDs/classes preserved for webforms.min.js. -->
    <div id="mlb2-39606735" class="ml-form-embedContainer ml-subscribe-form ml-subscribe-form-39606735 newsletter-form">
      <div class="row-form">
        <form class="ml-block-form" action="https://assets.mailerlite.com/jsonp/2253595/forms/184178172407841870/subscribe" data-code="" method="post" target="_blank">
          <div class="newsletter-row">
            <input aria-label="email" aria-required="true" type="email" class="newsletter-input form-control" name="fields[email]" placeholder="you@domain.com" autocomplete="email" required />
            <button type="submit" class="newsletter-submit primary">Count me in</button>
          </div>
          <!-- reCAPTCHA lives inside a modal but remains a child of the form,
               so MailerLite's webforms.min.js still finds grecaptcha.getResponse() -->
          <div class="captcha-modal" id="caiCaptchaModal" hidden>
            <div class="captcha-modal-backdrop" data-captcha-close></div>
            <div class="captcha-modal-card" role="dialog" aria-modal="true" aria-labelledby="caiCaptchaTitle">
              <button type="button" class="captcha-modal-close" data-captcha-close aria-label="Close">×</button>
              <p class="captcha-modal-title" id="caiCaptchaTitle">Quick check: are you human?</p>
              <div class="ml-form-recaptcha ml-validate-required newsletter-recaptcha">
                <div class="g-recaptcha" data-sitekey="6Lf1KHQUAAAAAFNKEX1hdSWCS3mRMv4FlFaNslaD" data-callback="caiCaptchaSolved"></div>
              </div>
            </div>
          </div>
          <input type="hidden" name="ml-submit" value="1" />
          <input type="hidden" name="anticsrf" value="true" />
        </form>
      </div>
      <div class="row-success" style="display: none;">
        <p class="newsletter-success">✓ You're in! Check your inbox for confirmation. We'll ping you when the Discord opens.</p>
      </div>
    </div>
  </div>
</section>

<!-- MailerLite + reCAPTCHA wiring. IDs/classes above must match. -->
<script is:inline src="https://www.google.com/recaptcha/api.js" async defer></script>
<script is:inline>
  function ml_webform_success_39606735() {
    var container = document.getElementById('mlb2-39606735');
    if (!container) return;
    var form = container.querySelector('.row-form');
    var success = container.querySelector('.row-success');
    if (form) form.style.display = 'none';
    if (success) success.style.display = 'block';
  }
</script>
<script is:inline src="https://groot.mailerlite.com/js/w/webforms.min.js?v95037e5bac78f29ed026832ca21a7c7b" type="text/javascript"></script>
<script is:inline>
  fetch("https://assets.mailerlite.com/jsonp/2253595/forms/184178172407841870/takel");
</script>

<script is:inline>
  // Newsletter captcha modal — show reCAPTCHA only after user clicks submit.
  (function () {
    var container = document.getElementById('mlb2-39606735');
    if (!container) return;
    var form = container.querySelector('form');
    var modal = document.getElementById('caiCaptchaModal');
    var submitBtn = container.querySelector('.newsletter-submit');
    var emailInput = container.querySelector('input[type=email]');
    if (!form || !modal || !submitBtn || !emailInput) return;

    var captchaSolved = false;

    submitBtn.addEventListener('click', function (e) {
      if (captchaSolved) return;
      if (!emailInput.checkValidity()) return;
      e.preventDefault();
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    });

    modal.addEventListener('click', function (e) {
      if (e.target.hasAttribute('data-captcha-close')) {
        modal.hidden = true;
        document.body.style.overflow = '';
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.hidden) {
        modal.hidden = true;
        document.body.style.overflow = '';
      }
    });

    window.caiCaptchaSolved = function () {
      captchaSolved = true;
      modal.hidden = true;
      document.body.style.overflow = '';
      submitBtn.click();
    };
  })();
</script>

<style>
  .newsletter-callout {
    background: #0A0A0A;
    padding: 5rem 0 5rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .container {
    max-width: 580px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    font-weight: 600;
    color: #808080;
    margin: 0 0 0.85rem;
  }

  .title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: #FFFFFF;
    margin: 0 0 0.6rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .subtitle {
    color: #909090;
    font-size: 0.98rem;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Newsletter form — overrides MailerLite defaults */
  :global(#mlb2-39606735.newsletter-form) {
    max-width: 460px;
    margin: 0 auto;
    text-align: center;
  }
  :global(#mlb2-39606735.newsletter-form .row-form),
  :global(#mlb2-39606735.newsletter-form .row-success) {
    background: transparent;
    padding: 0;
    border: 0;
  }
  :global(#mlb2-39606735.newsletter-form form) {
    margin: 0;
    width: 100%;
  }
  :global(#mlb2-39606735.newsletter-form .newsletter-row) {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }
  :global(#mlb2-39606735.newsletter-form .newsletter-input) {
    flex: 1;
    background: rgba(255, 255, 255, 0.06) !important;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    border-radius: 12px !important;
    padding: 0.85rem 1rem !important;
    color: #FFFFFF !important;
    font-size: 0.95rem !important;
    font-family: inherit !important;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease;
    box-sizing: border-box !important;
    width: auto !important;
    max-width: none !important;
    line-height: 1.4 !important;
    height: auto !important;
    margin: 0 !important;
  }
  :global(#mlb2-39606735.newsletter-form .newsletter-input::placeholder) {
    color: rgba(255, 255, 255, 0.45) !important;
  }
  :global(#mlb2-39606735.newsletter-form .newsletter-input:focus) {
    border-color: rgba(167, 139, 250, 0.6) !important;
    background: rgba(255, 255, 255, 0.09) !important;
  }
  :global(#mlb2-39606735.newsletter-form .newsletter-submit) {
    background: rgba(255, 255, 255, 0.1) !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
    color: #FFFFFF !important;
    padding: 0.85rem 1.25rem !important;
    border-radius: 12px !important;
    font-weight: 600 !important;
    font-size: 0.9rem !important;
    font-family: inherit !important;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s ease;
    box-shadow: none !important;
    width: auto !important;
    height: auto !important;
    line-height: 1.4 !important;
    margin: 0 !important;
  }
  :global(#mlb2-39606735.newsletter-form .newsletter-submit:hover) {
    background: rgba(255, 255, 255, 0.16) !important;
    border-color: rgba(255, 255, 255, 0.3) !important;
  }
  :global(#mlb2-39606735.newsletter-form .newsletter-recaptcha) {
    display: flex;
    justify-content: center;
    float: none !important;
    margin: 0 !important;
  }
  :global(#mlb2-39606735.newsletter-form .newsletter-success) {
    margin: 0;
    padding: 1rem 1.25rem;
    background: rgba(167, 139, 250, 0.1);
    border: 1px solid rgba(167, 139, 250, 0.25);
    border-radius: 12px;
    color: #D0D0D0;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  :global(#mlb2-39606735.newsletter-form button.loading) {
    display: none;
  }

  /* Captcha modal */
  :global(#mlb2-39606735 .captcha-modal) {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  :global(#mlb2-39606735 .captcha-modal[hidden]) {
    display: none;
  }
  :global(#mlb2-39606735 .captcha-modal-backdrop) {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    animation: captcha-fade 0.2s ease-out;
  }
  :global(#mlb2-39606735 .captcha-modal-card) {
    position: relative;
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 2rem 1.75rem 1.75rem;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
    max-width: 360px;
    width: 100%;
    text-align: center;
    animation: captcha-pop 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  :global(#mlb2-39606735 .captcha-modal-close) {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: transparent;
    border: 0;
    color: #808080;
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    transition: color 0.15s ease;
  }
  :global(#mlb2-39606735 .captcha-modal-close:hover) {
    color: #FFFFFF;
  }
  :global(#mlb2-39606735 .captcha-modal-title) {
    margin: 0 0 1.25rem;
    color: #E5E5E5;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
  }
  @keyframes captcha-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes captcha-pop {
    from { opacity: 0; transform: translateY(8px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (max-width: 560px) {
    .newsletter-callout {
      padding: 3.5rem 0;
    }
    :global(#mlb2-39606735.newsletter-form .newsletter-row) {
      flex-direction: column;
      gap: 0.6rem;
    }
    :global(#mlb2-39606735.newsletter-form .newsletter-submit) {
      width: 100% !important;
    }
  }
</style>
