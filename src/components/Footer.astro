---
import githubLogo from '../assets/images/GitHub_Invertocat_Black.svg';
import discordLogo from '../assets/images/discord-white-icon.png';
import raycastLogo from '../assets/images/logo-raycast.png';
import caiLogoBorder from '../assets/images/cai-logo-border.svg';

const footerLinks = [
  { name: "Guide", url: "https://github.com/soyasis/cai-clipboard-ai#-installation" },
  { name: "Community", url: "https://www.raycast.com/community" },
  { name: "Raycast Store", url: "https://www.raycast.com/store" },
  { name: "Imprint", url: "/imprint" },
  { name: "Privacy", url: "/privacy" },
  { name: "Terms of Service", url: "https://www.raycast.com/terms-of-service" }
];
---

<footer class="footer">
  <div class="container">
    <!-- CTA Section -->
    <div class="footer-cta">
      <h2 class="cta-title">Get Cai</h2>
      <div class="cta-actions">
        <a href="https://raycast.com" class="cta-button" target="_blank" rel="noopener noreferrer">
          <img src={raycastLogo.src} alt="Raycast" class="button-logo" />
          <span>Download from Raycast</span>
        </a>
        <a href="https://github.com/soyasis/cai-clipboard-ai" class="cta-button github-button" target="_blank" rel="noopener noreferrer">
          <img src={githubLogo.src} alt="GitHub" class="button-logo" />
          <span>Download from GitHub</span>
        </a>
      </div>
    </div>

    <!-- Footer Links -->
    <div class="footer-content">
      <nav class="footer-nav">
        {footerLinks.map((link) => (
          <a href={link.url} class="footer-link">
            {link.name}
          </a>
        ))}
      </nav>

      <div class="footer-social">
        <!-- <a
          href="https://github.com/soyasis/cai-clipboard-ai"
          class="social-link"
          aria-label="GitHub"
          target="_blank"
          rel="noopener noreferrer"
        >
          <img src={githubLogo.src} alt="GitHub" width="20" height="20" />
        </a> -->

        <!-- <a
          href="https://discord.com"
          class="social-link"
          aria-label="Discord"
          target="_blank"
          rel="noopener noreferrer"
        >
          <img src={discordLogo.src} alt="Discord" width="20" height="20" />
        </a> -->
      </div>

      <div class="footer-logo">
        <img src={caiLogoBorder.src} alt="Cai" class="logo-image" />
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background:
      radial-gradient(ellipse 800px 900px at 30% 50%, rgba(167, 139, 250, 0.12) 0%, transparent 70%),
      radial-gradient(ellipse 700px 800px at 70% 50%, rgba(255, 105, 180, 0.1) 0%, transparent 70%),
      linear-gradient(180deg, #0A0A0A 0%, #111111 100%);
    color: #ffffff;
    padding: 6rem 0 3.5rem;
    position: relative;
    overflow: hidden;
  }

  .footer::before {
    content: '';
    position: absolute;
    top: 20%;
    left: 10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.15) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .footer::after {
    content: '';
    position: absolute;
    bottom: 20%;
    right: 10%;
    width: 550px;
    height: 550px;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.12) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .footer-cta {
    text-align: center;
    margin-bottom: 5rem;
    padding-bottom: 5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .cta-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: white;
    margin-bottom: 2rem;
    font-weight: 700;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #FFFFFF;
    color: #1A1A1A;
    padding: 0.85rem 1.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .cta-button:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    background: #F5F5F5;
  }

  .button-logo {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    flex: 1;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.3s ease;
    white-space: nowrap;
    position: relative;
  }

  .footer-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: white;
    transition: width 0.3s ease;
  }

  .footer-link:hover {
    color: white;
    transform: translateY(-2px);
  }

  .footer-link:hover::after {
    width: 100%;
  }

  .footer-social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .social-link {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 10px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    backdrop-filter: blur(10px);
  }

  .social-link img {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  .social-link:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: translateY(-4px) scale(1.1);
  }

  .footer-logo {
    display: flex;
    align-items: center;
  }

  .logo-image {
    height: 48px;
    width: auto;
    transition: all 0.3s ease;
  }

  .logo-image:hover {
    transform: scale(1.05);
  }

  @media (max-width: 968px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
      gap: 2.5rem;
    }

    .footer-nav {
      justify-content: center;
      order: 1;
      gap: 1.5rem;
    }

    .footer-logo {
      order: 2;
    }

    .footer-social {
      order: 3;
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding: 2.5rem 0;
    }

    .footer-nav {
      gap: 1.25rem;
      font-size: 0.85rem;
    }

    .logo-image {
      height: 40px;
    }
  }
</style>
