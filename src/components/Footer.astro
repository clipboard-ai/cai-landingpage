---
import caiLogoBorder from '../assets/images/cai-logo-border.svg';

const footerGroups = [
  {
    label: "Product",
    links: [
      { name: "Docs", url: "/docs/" },
      { name: "Releases", url: "https://github.com/cai-layer/cai/releases/latest" },
      { name: "Models", url: "https://github.com/cai-layer/cai#recommended-models" },
      { name: "Extensions", url: "https://github.com/cai-layer/cai-extensions" },
    ]
  },
  {
    label: "Community",
    links: [
      { name: "GitHub", url: "https://github.com/cai-layer/cai" },
      { name: "Discussions", url: "https://github.com/cai-layer/cai/discussions" },
      { name: "Report Issues", url: "https://github.com/cai-layer/cai/issues" },
      { name: "LinkedIn", url: "https://www.linkedin.com/company/cai-layer" },
    ]
  },
  {
    label: "Comparisons",
    links: [
      { name: "Cai vs ChatGPT", url: "/vs/chatgpt/" },
      { name: "Cai vs Raycast", url: "/vs/raycast/" },
      { name: "Cai vs BoltAI", url: "/vs/boltai/" },
      { name: "Cai vs Alter", url: "/vs/alter/" },
    ]
  },
  {
    label: "Legal",
    links: [
      { name: "Imprint", url: "/imprint/" },
      { name: "Privacy", url: "/privacy/" },
      { name: "Terms of Service", url: "/terms/" },
    ]
  }
];
---

<footer class="footer">
  <div class="container">
    <!-- CTA Section -->
    <div class="footer-cta">
      <h2 class="cta-title">Free & <span class="highlight">Open Source</span>.</h2>
      <p class="cta-subtitle">No subscriptions. No telemetry. AI actions, anywhere.</p>
      <blockquote class="cta-quote">
        "Used it all day working. This is awesome."
        <cite>@aretheworsst on r/LocalLLM</cite>
      </blockquote>

      <a href="https://github.com/cai-layer/cai/releases/download/v1.4.0/Cai-1.4.0-macos.dmg" class="cta-button" target="_blank" rel="noopener noreferrer">
        <svg class="apple-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" fill="currentColor"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
        <span>Download for Mac</span>
      </a>
    </div>

    <!-- Footer Links -->
    <div class="footer-content">
      <div class="footer-groups">
        {footerGroups.map((group) => (
          <div class="footer-group">
            <span class="footer-group-label">{group.label}</span>
            <nav class="footer-group-links">
              {group.links.map((link) => (
                <a href={link.url} class="footer-link" target={link.url.startsWith('/') ? undefined : '_blank'} rel={link.url.startsWith('/') ? undefined : 'noopener noreferrer'}>
                  {link.name}
                </a>
              ))}
            </nav>
          </div>
        ))}
      </div>

      <div class="footer-logo">
        <img src={caiLogoBorder.src} alt="Cai - AI Action Layer for macOS" class="logo-image" />
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(135deg, #A78BFA 0%, #D380C3 50%, #F78595 100%);
    background-size: 200% 200%;
    animation: gradient-shift 8s ease infinite;
    color: #ffffff;
    padding: 5rem 0 3.5rem;
    position: relative;
    overflow: hidden;
  }

  .footer::before {
    content: '';
    position: absolute;
    top: -30%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
    border-radius: 50%;
    animation: float-up 7s ease-in-out infinite alternate;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* CTA Section */
  .footer-cta {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    color: white;
    margin-bottom: 1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.15);
  }

  .highlight {
    color: #1A1A1A;
  }

  .cta-subtitle {
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .cta-quote {
    max-width: 500px;
    margin: 0 auto 2.5rem;
    padding: 0;
    border: none;
    font-style: italic;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
  }

  .cta-quote cite {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    font-style: normal;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: white;
    color: #1A1A1A;
    padding: 0.85rem 1.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 10px 35px rgba(0, 0, 0, 0.25), 0 4px 12px rgba(0, 0, 0, 0.15);
  }

  .cta-button:hover {
    transform: translateY(-5px) scale(1.03);
    box-shadow: 0 15px 45px rgba(0, 0, 0, 0.3), 0 6px 16px rgba(0, 0, 0, 0.2);
    background: #F5F5F5;
  }

  .apple-icon {
    width: 18px;
    height: 18px;
  }

  /* Footer Links */
  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
  }

  .footer-groups {
    display: flex;
    gap: 4rem;
    flex: 1;
  }

  .footer-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-group-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-group-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.3s ease;
    white-space: nowrap;
    position: relative;
  }

  .footer-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: white;
    transition: width 0.3s ease;
  }

  .footer-link:hover {
    color: white;
    transform: translateY(-2px);
  }

  .footer-link:hover::after {
    width: 100%;
  }

  .footer-logo {
    display: flex;
    align-items: center;
  }

  .logo-image {
    height: 32px;
    width: auto;
    transition: all 0.3s ease;
  }

  .logo-image:hover {
    transform: scale(1.05);
  }

  @media (max-width: 968px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
      gap: 2.5rem;
    }

    .footer-groups {
      justify-content: center;
      order: 1;
    }

    .footer-group {
      align-items: center;
    }

    .footer-logo {
      order: 2;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding: 4rem 0 2.5rem;
    }

    .footer-cta {
      margin-bottom: 3rem;
      padding-bottom: 3rem;
    }

    .cta-button {
      padding: 1rem 2rem;
      font-size: 1rem;
    }

    .footer-groups {
      gap: 2.5rem;
    }

    .footer-link {
      font-size: 0.85rem;
    }

    .logo-image {
      height: 40px;
    }
  }

  @media (max-width: 480px) {
    .footer-groups {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem 1.5rem;
      width: 100%;
    }

    .footer-group {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
