<style>
  .footer-cta {
    background: linear-gradient(135deg, #A78BFA 0%, #D380C3 50%, #F78595 100%);
    background-size: 200% 200%;
    animation: gradient-shift 8s ease infinite;
    padding: 5rem 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .footer-cta::before {
    content: '';
    position: absolute;
    top: -30%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
    border-radius: 50%;
    animation: float-up 7s ease-in-out infinite alternate;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    color: white;
    margin-bottom: 1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.15);
  }

  .highlight {
    color: #1A1A1A;
  }

  .cta-subtitle {
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    margin-bottom: 2.5rem;
    font-weight: 500;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: white;
    color: #1A1A1A;
    padding: 1rem 2.5rem;
    border-radius: 14px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 10px 35px rgba(0, 0, 0, 0.25), 0 4px 12px rgba(0, 0, 0, 0.15);
  }

  .cta-button:hover {
    transform: translateY(-5px) scale(1.03);
    box-shadow: 0 15px 45px rgba(0, 0, 0, 0.3), 0 6px 16px rgba(0, 0, 0, 0.2);
    background: #F5F5F5;
  }

  .apple-icon {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 768px) {
    .footer-cta {
      padding: 4rem 0;
    }

    .cta-button {
      padding: 0.9rem 2rem;
      font-size: 1rem;
    }
  }
</style>
