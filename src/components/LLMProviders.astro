---
import lmStudioLogo from '../assets/images/logo-lm-studio.png';
import ollamaLogo from '../assets/images/logo-ollama.png';
import openRouterLogo from '../assets/images/logo-openrouter.svg';
import huggingFaceLogo from '../assets/images/logo-hf.svg';
const localProviders = [
  { name: "LM Studio", logo: lmStudioLogo },
  { name: "Ollama", logo: ollamaLogo },
  { name: "OpenRouter", logo: openRouterLogo },
  { name: "Hugging Face", logo: huggingFaceLogo },
];
---

<section class="llm-providers">
  <div class="container">
    <h2 class="section-title">Bring Your Own <span class="highlight">Brain</span></h2>
    <p class="section-subtitle">
      Use our built-in model, load any model from the <a href="https://huggingface.co/mlx-community" target="_blank" rel="noopener noreferrer" class="inline-link">HuggingFace MLX community</a>, connect to a local server, or use a cloud provider like <a href="https://openrouter.ai" target="_blank" rel="noopener noreferrer" class="inline-link">OpenRouter</a>.
    </p>

    <div class="provider-grid">
      {localProviders.map((provider, index) => (
        <div class="provider-card" style={`animation-delay: ${index * 0.1}s`}>
          <div class="provider-logo-wrapper">
            <img
              src={provider.logo.src}
              alt={provider.name}
              class="provider-logo"
            />
          </div>
          <span class="provider-name">{provider.name}</span>
        </div>
      ))}
    </div>

    <div class="model-badges">
      <span class="model-badge built-in">MLX Community<span class="badge-tag">built-in</span></span>
      <span class="model-badge built-in">Apple Intelligence <span class="badge-tag">built-in</span></span>
    </div>
    <div class="model-badges model-badges--secondary">
      <span class="model-badge">Llama</span>
      <span class="model-badge">Mistral</span>
      <span class="model-badge">Qwen</span>
      <span class="model-badge">Gemma</span>
      <span class="model-badge">Phi</span>
      <span class="model-badge">DeepSeek</span>
      <span class="model-badge">LFM2</span>
      <span class="model-badge more">...</span>
    </div>

    <a href="/docs/getting-started/llm-setup/#choosing-a-model" class="models-link">
      Which model should I use? →
    </a>
  </div>
</section>

<style>
  .llm-providers {
    padding: 7rem 0;
    background: #0F0F0F;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    text-align: center;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    text-align: center;
    color: #909090;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 720px;
    margin: 0 auto 3rem;
    line-height: 1.65;
  }

  .inline-link {
    color: var(--accent-light);
    text-decoration: none;
    border-bottom: 1px solid rgba(167, 139, 250, 0.3);
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .inline-link:hover {
    color: #FFFFFF;
    border-bottom-color: rgba(167, 139, 250, 0.6);
  }

  .provider-group-label {
    text-align: center;
    color: #606060;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .provider-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto 2.5rem;
    align-items: stretch;
  }

  .provider-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem 1rem;
    transition: all 0.3s ease;
    animation: scale-in 0.5s ease-out both;
  }

  .provider-card:hover {
    transform: translateY(-4px);
  }

  .provider-logo-wrapper {
    width: 90px;
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 50%;
    padding: 1rem;
    transition: all 0.3s ease;
  }

  .provider-card:hover .provider-logo-wrapper {
    background: rgba(255, 255, 255, 1);
    transform: scale(1.08);
    box-shadow: 0 8px 25px rgba(167, 139, 250, 0.2);
  }

  .provider-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: grayscale(20%);
    transition: filter 0.3s ease;
  }

  .provider-card:hover .provider-logo {
    filter: grayscale(0%);
  }

  .provider-name {
    color: #E0E0E0;
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
    max-width: 100%;
    word-wrap: break-word;
  }

  .model-badges {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .model-badges--secondary {
    margin-top: 0.75rem;
  }

  .model-badge {
    padding: 0.4rem 1rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    color: #B0B0B0;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .model-badge.built-in {
    border-color: rgba(167, 139, 250, 0.3);
    color: #C4B5FD;
    background: rgba(167, 139, 250, 0.08);
  }

  .badge-tag {
    font-size: 0.65rem;
    padding: 0.1rem 0.45rem;
    border-radius: 100px;
    background: rgba(167, 139, 250, 0.2);
    color: #C4B5FD;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-left: 0.25rem;
    vertical-align: middle;
  }

  .model-badge.more {
    color: #707070;
  }

  .models-link {
    display: block;
    text-align: center;
    margin-top: 2.5rem;
    color: #909090;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .models-link:hover {
    color: var(--accent-light);
  }

  @media (max-width: 768px) {
    .llm-providers {
      padding: 5rem 0;
    }

    .provider-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      max-width: 100%;
    }

    .provider-card {
      padding: 1rem 0.25rem;
      gap: 0.6rem;
    }

    .provider-logo-wrapper {
      width: 64px;
      height: 64px;
      padding: 0.75rem;
    }

    .provider-name {
      font-size: 0.8rem;
    }
  }
</style>
