---
import lmStudioLogo from '../assets/images/logo-lm-studio.png';
import ollamaLogo from '../assets/images/logo-ollama.png';
import janAiLogo from '../assets/images/logo-jan-ai.png';
import localAiLogo from '../assets/images/logo-local-ai.png';
import vllmLogo from '../assets/images/logo-vllm.png';
import textGenLogo from '../assets/images/logo-text-generation-web-ui.png';
import anythingLlmLogo from '../assets/images/logo-anything-llm.png';
import mstyAiLogo from '../assets/images/logo-msty-AI.png';
import openWebUiLogo from '../assets/images/logo-open-webui.png';
import gpt4allLogo from '../assets/images/logo-gpt4all.png';

const providers = [
  { name: "LM Studio", logo: lmStudioLogo },
  { name: "Ollama", logo: ollamaLogo },
  { name: "Jan AI", logo: janAiLogo },
  { name: "Local AI", logo: localAiLogo },
  { name: "vLLM", logo: vllmLogo },
  { name: "Text Generation Web UI", logo: textGenLogo },
  { name: "Anything LLM", logo: anythingLlmLogo },
  { name: "Msty AI", logo: mstyAiLogo },
  { name: "Open WebUI", logo: openWebUiLogo },
  { name: "GPT4All", logo: gpt4allLogo }
];
---

<section class="llm-providers">
  <div class="container">
    <h2 class="section-title">Bring Your Own Brain</h2>
    <p class="section-subtitle">
      Cai doesn't lock you in. It plugs into the local AI ecosystem you already use.
    </p>

    <div class="provider-grid">
      {providers.map((provider, index) => (
        <div class="provider-card" style={`animation-delay: ${index * 0.1}s`}>
          <div class="provider-logo-wrapper">
            <img
              src={provider.logo.src}
              alt={provider.name}
              class="provider-logo"
            />
          </div>
          <span class="provider-name">{provider.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .llm-providers {
    padding: 7rem 0;
    background: #0F0F0F;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-align: center;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    text-align: center;
    color: #909090;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 720px;
    margin: 0 auto 5rem;
    line-height: 1.65;
  }

  .provider-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    align-items: stretch;
  }

  .provider-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 2rem 1.5rem;
    background: rgba(25, 25, 25, 0.8);
    border-radius: 20px;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: scale-in 0.5s ease-out both;
    border: 2px solid rgba(167, 139, 250, 0.1);
    min-height: 220px;
  }

  .provider-card:hover {
    transform: translateY(-10px) scale(1.05);
    box-shadow: 0 15px 40px rgba(211, 128, 195, 0.3);
    border-color: var(--accent-pink);
    background: rgba(30, 30, 30, 0.9);
  }

  .provider-logo-wrapper {
    width: 90px;
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 50%;
    padding: 1rem;
    transition: all 0.3s ease;
  }

  .provider-card:hover .provider-logo-wrapper {
    background: rgba(255, 255, 255, 1);
    transform: rotate(-5deg) scale(1.1);
  }

  .provider-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: grayscale(20%);
    transition: filter 0.3s ease;
  }

  .provider-card:hover .provider-logo {
    filter: grayscale(0%);
  }

  .provider-name {
    color: #E0E0E0;
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
    max-width: 100%;
    word-wrap: break-word;
  }

  @media (max-width: 1100px) {
    .provider-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .llm-providers {
      padding: 5rem 0;
    }

    .provider-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.75rem;
    }

    .provider-card {
      padding: 1.5rem 1rem;
      min-height: 180px;
    }

    .provider-logo-wrapper {
      width: 70px;
      height: 70px;
    }
  }
</style>
