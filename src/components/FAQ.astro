---
const faqs = [
  {
    question: "Is Cai secure?",
    answer: "<p>Yes. Cai runs locally on your Mac by default. If you choose to connect a cloud model, your text is sent to that provider — but this is entirely opt-in. By default, everything stays on your machine.</p>"
  },
  {
    question: "How is Cai different from other tools?",
    answer: "<p>Clipboard managers store and organize what you copy — Cai acts on it. And unlike ChatGPT or other AI tools that require switching to a separate app, Cai works directly on your selected text in any app, without breaking your flow. It connects to your tools — create GitHub issues or Linear tickets without leaving your workflow. It's an AI action layer that runs locally on your Mac by default.</p>"
  },
  {
    question: "Why does Cai need Accessibility permissions?",
    answer: "<p>Cai uses the system hotkey ⌥C to copy your selected text via a simulated ⌘C. macOS requires Accessibility access for apps that interact with system-level keyboard commands. This is what allows Cai to work seamlessly across all apps.</p><p>To enable it: open <strong>System Settings → Privacy & Security → Accessibility</strong> and toggle Cai on.</p>"
  },
  {
    question: "What models does Cai support?",
    answer: "<p>Cai ships with Ministral 3B built in as the default — on par with Apple Intelligence for most actions, no setup needed. The curated picker also includes Qwen 2.5 7B for Macs with 16 GB+ RAM. It also supports Apple Intelligence on macOS 26+ (M1 or later), local servers like LM Studio, Ollama, and Jan AI, and cloud providers like OpenAI, Google Gemini, Mistral, and OpenRouter.</p><p>You can also load any model from the <a href='https://huggingface.co/mlx-community' target='_blank' rel='noopener noreferrer'>HuggingFace mlx-community</a> by entering its repo ID in Settings.</p>"
  },
  {
    question: "How do I create custom actions?",
    answer: "<p>Open Cai's settings and go to Custom Actions. You can create prompt actions (saved AI instructions), URL actions (templates with %s for your selected text), or shell actions that execute commands using your clipboard data. Once saved, they appear in your action list for one-tap access.</p><p>You can also create custom destinations to route AI results anywhere — via webhooks, deeplinks, AppleScript, or shell commands.</p><p>Browse and install actions shared by the community at <a href='https://github.com/cai-layer/cai-extensions' target='_blank' rel='noopener noreferrer'>cai-extensions</a>.</p>"
  },
  {
    question: "Does Cai work offline?",
    answer: "<p>Yes. Once installed and connected to a local model, Cai works completely offline with no internet connection required.</p>"
  },
  {
    question: "Is Cai really free?",
    answer: "<p>Yes. Cai is free and open source under the MIT license. No telemetry, no tracking. Some advanced features may be offered as a paid option in the future, but the core app will always remain free and open source.</p>"
  }
];


// Generate FAQPage structured data
const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<[^>]*>/g, '')
    }
  }))
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(faqStructuredData)} />

<section class="faq">
  <div class="container">
    <h2 class="section-title">Frequently Asked <span class="highlight">Questions</span></h2>

    <div class="faq-list">
      {faqs.map(faq => (
        <details class="faq-item">
          <summary class="faq-question">
            <span>{faq.question}</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-answer" set:html={faq.answer} />
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach(item => {
    item.addEventListener('toggle', () => {
      if (item.open) {
        document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach(other => {
          if (other !== item) other.open = false;
        });
      }
    });
  });
</script>

<style>
  .faq {
    padding: 7rem 0;
    background: #0E0E0E;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    text-align: center;
    margin-bottom: 4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .faq-list {
    max-width: 740px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .faq-item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem 0;
    color: #FFFFFF;
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s ease;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    display: none;
    content: '';
  }

  .faq-question:hover {
    color: #C4B5FD;
  }

  .faq-chevron {
    flex-shrink: 0;
    color: #606060;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: #C4B5FD;
  }

  .faq-answer {
    padding: 0 0 1.5rem;
  }

  .faq-answer :global(p) {
    color: #909090;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .faq-answer :global(p + p) {
    margin-top: 0.75rem;
  }

  .faq-answer :global(a) {
    color: #C4B5FD;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .faq-answer :global(a:hover) {
    color: #F78595;
  }

  .faq-answer :global(strong) {
    color: #C4B5FD;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .faq {
      padding: 5rem 0;
    }

    .faq-question {
      font-size: 0.95rem;
      padding: 1.25rem 0;
    }

    .faq-answer :global(p) {
      font-size: 0.9rem;
    }
  }
</style>
