---
const faqs = [
  {
    question: "Is Cai secure?",
    answer: "<p>Yes. Cai runs locally on your Mac by default. If you choose to connect a cloud model, your text is sent to that provider — but this is entirely opt-in. By default, everything stays on your machine.</p>"
  },
  {
    question: "How is Cai different from clipboard managers?",
    answer: "<p>Clipboard managers are built to store and organize what you copy. Cai is built to act on it — summarize, reply, translate, extract text from images, or run any AI prompt on your clipboard content, right where you are. It's a text action layer, not a clipboard organizer.</p>"
  },
  {
    question: "How is Cai different from ChatGPT or other AI tools?",
    answer: "<p>Most AI tools require you to switch to a separate app or browser tab. Cai works directly on your selected text, in any app, without breaking your flow — and everything runs locally on your Mac by default.</p>"
  },
  {
    question: "Why does Cai need Accessibility permissions?",
    answer: "<p>Cai uses the system hotkey ⌥C to copy your selected text via a simulated ⌘C. macOS requires Accessibility access for apps that interact with system-level keyboard commands. This is what allows Cai to work seamlessly across all apps.</p><p>To enable it: open <strong>System Settings → Privacy & Security → Accessibility</strong> and toggle Cai on.</p>"
  },
  {
    question: "Do I need a model provider?",
    answer: "<p>No — Cai ships with a built-in model (Ministral 3B) that you can download on first launch. It works out of the box with no setup needed.</p><p>You can also add your own GGUF models — just drop them into <code>~/Library/Application Support/Cai/models/</code>.</p><p>If you want to use a different provider, you can connect a local server (LM Studio, Ollama, etc.) or a cloud provider (OpenAI, Gemini, Mistral, OpenRouter, etc.) in settings.</p>"
  },
  {
    question: "Does Cai work with Apple Intelligence?",
    answer: "<p>Yes. Cai supports Apple Intelligence as a built-in model provider on Macs with an M1 chip or later running macOS 26+. If Apple Intelligence is active on your Mac, Cai will suggest it automatically after install.</p><p>You can also enable it manually in <strong>Settings → Model → Apple Intelligence</strong>. Make sure Apple Intelligence is enabled on your Mac under <strong>System Settings → Apple Intelligence & Siri</strong>.</p>"
  },
  {
    question: "How do I create custom actions?",
    answer: "<p>Open Cai's settings from the menu bar icon and go to Custom Actions. You can create prompt shortcuts (saved AI instructions) or URL shortcuts (templates with %s for your selected text). Once saved, they appear in your action list for one-tap access.</p><p>You can also browse and install actions shared by the community at <a href='https://github.com/clipboard-ai/cai-extensions' target='_blank' rel='noopener noreferrer'>cai-extensions</a>.</p>"
  },
  {
    question: "What models does Cai support?",
    answer: "<p>Cai ships with Ministral 3B built in — no setup needed. It also supports Apple Intelligence on macOS 26+, local servers like LM Studio, Ollama, and Jan AI, and cloud providers like OpenAI, Google Gemini, Mistral, and OpenRouter. You can also load your own GGUF models.</p>"
  },
  {
    question: "Does Cai work offline?",
    answer: "<p>Yes. With the built-in Ministral 3B model or any local provider (LM Studio, Ollama), Cai works completely offline with no internet connection required.</p>"
  },
  {
    question: "Is Cai really free?",
    answer: "<p>Yes — Cai is 100% free and open source under the MIT license. No subscriptions, no premium tiers, no telemetry. It's free forever.</p>"
  }
];


// Generate FAQPage structured data
const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<[^>]*>/g, '')
    }
  }))
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(faqStructuredData)} />

<section class="faq">
  <div class="container">
    <h2 class="section-title">Frequently Asked <span class="highlight">Questions</span></h2>

    <div class="faq-list">
      {faqs.map(faq => (
        <details class="faq-item">
          <summary class="faq-question">
            <span>{faq.question}</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-answer" set:html={faq.answer} />
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach(item => {
    item.addEventListener('toggle', () => {
      if (item.open) {
        document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach(other => {
          if (other !== item) other.open = false;
        });
      }
    });
  });
</script>

<style>
  .faq {
    padding: 7rem 0;
    background: #0E0E0E;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    text-align: center;
    margin-bottom: 4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .faq-list {
    max-width: 740px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .faq-item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem 0;
    color: #FFFFFF;
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s ease;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    display: none;
    content: '';
  }

  .faq-question:hover {
    color: #C4B5FD;
  }

  .faq-chevron {
    flex-shrink: 0;
    color: #606060;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: #C4B5FD;
  }

  .faq-answer {
    padding: 0 0 1.5rem;
  }

  .faq-answer :global(p) {
    color: #909090;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .faq-answer :global(p + p) {
    margin-top: 0.75rem;
  }

  .faq-answer :global(a) {
    color: #C4B5FD;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .faq-answer :global(a:hover) {
    color: #F78595;
  }

  .faq-answer :global(strong) {
    color: #C4B5FD;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .faq {
      padding: 5rem 0;
    }

    .faq-question {
      font-size: 0.95rem;
      padding: 1.25rem 0;
    }

    .faq-answer :global(p) {
      font-size: 0.9rem;
    }
  }
</style>
