---
const faqs = [
  {
    question: "Is Cai free?",
    answer: "Yes, Cai is completely free and open source under the MIT license. No subscriptions, no hidden fees, no premium tiers."
  },
  {
    question: "Is Cai secure?",
    answer: "Yes. Cai runs 100% locally on your Mac. Your clipboard data and AI conversations never leave your machine — unless you explicitly configure a cloud model provider."
  },
  {
    question: "Why does Cai need Accessibility permissions?",
    answer: "Cai uses the system hotkey ⌥C to copy your selected text via a simulated ⌘C. macOS requires Accessibility access for apps that interact with system-level keyboard commands. This is what allows Cai to work seamlessly across all apps."
  },
  {
    question: "Do I need a model provider?",
    answer: "For AI-powered actions (Summarize, Reply, Translate, etc.), yes — you need a local model server like LM Studio or Ollama running. However, some built-in actions like Open in Maps, Create Calendar Event, Search the Web and Beautify JSON work without any model."
  },
  {
    question: "How do I create custom actions?",
    answer: "Open Cai's settings from the menu bar icon and go to Custom Actions. You can create prompt shortcuts (saved AI instructions) or URL shortcuts (templates with %s for your selected text). Once saved, they appear in your action list for one-tap access."
  },
  {
    question: "Does Cai work with cloud AI providers?",
    answer: "Yes. While Cai is designed for local-first AI, you can point it at any OpenAI-compatible endpoint — including cloud providers. Just enter the API URL in settings under \"Custom\" provider."
  }
];
---

<section class="faq">
  <div class="container">
    <h2 class="section-title">Frequently Asked <span class="highlight">Questions</span></h2>

    <div class="faq-list">
      {faqs.map(faq => (
        <details class="faq-item">
          <summary class="faq-question">
            <span>{faq.question}</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach(item => {
    item.addEventListener('toggle', () => {
      if (item.open) {
        document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach(other => {
          if (other !== item) other.open = false;
        });
      }
    });
  });
</script>

<style>
  .faq {
    padding: 7rem 0;
    background: #0E0E0E;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    text-align: center;
    margin-bottom: 4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .faq-list {
    max-width: 740px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .faq-item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem 0;
    color: #FFFFFF;
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s ease;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    display: none;
    content: '';
  }

  .faq-question:hover {
    color: #C4B5FD;
  }

  .faq-chevron {
    flex-shrink: 0;
    color: #606060;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: #C4B5FD;
  }

  .faq-answer {
    padding: 0 0 1.5rem;
  }

  .faq-answer p {
    color: #909090;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .faq {
      padding: 5rem 0;
    }

    .faq-question {
      font-size: 0.95rem;
      padding: 1.25rem 0;
    }

    .faq-answer p {
      font-size: 0.9rem;
    }
  }
</style>
