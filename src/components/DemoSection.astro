---
import ActionBadges from './ActionBadges.astro';

interface Props {
  title: string;
  subtitle?: string;
  mediaType?: 'image' | 'video';
  mediaSrc: any;
  posterSrc?: string;
  mediaAlt?: string;
  backgroundColor?: string;
  id?: string;
  actions?: Array<{ name: string; description: string; highlight?: boolean; secondary?: boolean }>;
  linkHref?: string;
  linkText?: string;
}

const {
  title,
  subtitle,
  mediaType = 'image',
  mediaSrc,
  posterSrc,
  mediaAlt = 'Demo screenshot',
  backgroundColor = '#ffffff',
  id,
  actions,
  linkHref,
  linkText
} = Astro.props;

const imageSrc = typeof mediaSrc === 'string' ? mediaSrc : mediaSrc.src;
---

<section class="demo-section" style={`background-color: ${backgroundColor};`} id={id}>
  <div class="container">
    <div class="demo-content">
      <h2 class="demo-title" set:html={title} />
      {subtitle && <p class="demo-subtitle" set:html={subtitle} />}
      {actions && <ActionBadges actions={actions} />}
      {linkHref && linkText && (
        <a href={linkHref} class="section-link" target="_blank" rel="noopener noreferrer">
          {linkText}
        </a>
      )}
    </div>

    <div class="demo-media">
      {mediaType === 'video' ? (
        <video
          class="media-element"
          autoplay
          loop
          muted
          playsinline
          poster={posterSrc}
          aria-label={mediaAlt}
          data-lazy-video
        >
          <source src={imageSrc} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      ) : (
        <img
          src={imageSrc}
          alt={mediaAlt}
          class="media-element"
        />
      )}
    </div>
  </div>
</section>

<style>
  .demo-section {
    padding: 7rem 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .demo-content {
    text-align: center;
    margin-bottom: 4rem;
  }

  .demo-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-wrap: balance;
    hyphens: none;
  }

  .demo-title :global(.highlight) {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .demo-subtitle {
    color: #909090;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.65;
  }

  .section-link {
    display: block;
    text-align: center;
    margin-top: 2rem;
    color: #909090;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .section-link:hover {
    color: var(--accent-light);
  }

  .demo-media {
    max-width: 980px;
    margin: 0 auto;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 25px 70px rgba(0, 0, 0, 0.5), 0 10px 30px rgba(0, 0, 0, 0.3);
    background: #000;
    transition: all 0.4s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .demo-media:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 35px 90px rgba(0, 0, 0, 0.6), 0 15px 40px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .media-element {
    width: 100%;
    height: auto;
    display: block;
  }

  video.media-element {
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .demo-section {
      padding: 5rem 0;
    }

    .demo-content {
      margin-bottom: 2.5rem;
    }

    .demo-media {
      border-radius: 16px;
    }
  }
</style>
