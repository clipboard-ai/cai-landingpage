---
---

<section class="hero" id="hero">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">
        Act on <span class="highlight">anything</span>. Locally.<br />
        <!-- Run <span class="highlight">custom actions</span>, locally. -->
      </h1>
      <p class="hero-subtitle">
        <!-- Select any text. Run custom AI prompts, shell scripts, OCR, GitHub or Linear tickets. Zero app switching. -->
        Press <span class="kbd"><span class="highlight">⌥C</span></span> to run custom AI prompts and scripts anywhere. Send results to GitHub, Linear or any API.
      </p>

      <div class="trust-badges">
        <a href="https://github.com/cai-layer/cai" class="trust-badge trust-badge-link" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          <span>Free &amp; Open Source</span>
        </a>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <span>100% Local</span>
        </div>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 L13.5 8.5 L19 10 L13.5 11.5 L12 17 L10.5 11.5 L5 10 L10.5 8.5 Z"/></svg>
          <span>Built-in AI</span>
        </div>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="18" y1="8" x2="23" y2="13"/><line x1="23" y1="8" x2="18" y2="13"/></svg>
          <span>No Account</span>
        </div>
      </div>

      <blockquote class="hero-quote">
        "You did in a very short time what Apple Intelligence failed to deliver."
        <cite>@nemuro87 on r/LocalLLM</cite>
      </blockquote>

      <div class="cta-row">
        <a href="https://www.producthunt.com/products/cai-layer?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-cai" class="ph-badge" target="_blank" rel="noopener noreferrer">
          <img alt="Cai on Product Hunt" width="250" height="54" src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1105432&theme=dark&t=1776701894509" />
        </a>
        <a href="https://github.com/cai-layer/cai/releases/download/v1.4.0/Cai-1.4.0-macos.dmg" class="cta-button" target="_blank" rel="noopener noreferrer">
          <svg class="apple-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" fill="currentColor"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
          <span>Download for Free</span>
        </a>
      </div>
      <div class="version-row">
        <a href="https://github.com/cai-layer/cai/releases/latest" class="version-info" target="_blank" rel="noopener noreferrer">v1.4.0</a>
        <span class="version-sep">&nbsp;|&nbsp;</span>
        <button class="brew-link" id="brew-trigger">Install via Homebrew</button>
      </div>
    </div>

    <!-- Homebrew modal -->
    <div class="brew-modal-overlay" id="brew-overlay">
      <div class="brew-modal">
        <h3 class="brew-modal-title">Install via Homebrew</h3>
        <p class="brew-modal-desc">To install Cai, run the following command in your terminal:</p>
        <div class="brew-command-row">
          <code class="brew-command">$ brew tap cai-layer/cai && brew install --cask cai</code>
          <button class="brew-copy-icon" id="brew-copy-icon" aria-label="Copy command">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
        </div>
        <div class="brew-modal-actions">
          <button class="brew-btn brew-btn-cancel" id="brew-cancel">Cancel</button>
          <button class="brew-btn brew-btn-copy" id="brew-copy">Copy</button>
        </div>
      </div>
    </div>

    <div class="hero-demo">
      <video
        class="demo-video"
        autoplay
        loop
        muted
        playsinline
        poster="/videos/cai-hero-poster.webp"
        aria-label="Cai action layer demo"
        title="Cai demo, run custom actions on any selected text"
        data-lazy-video
      >
        <source src="/videos/cai-hero.mp4" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>
  </div>
</section>

<script>
  const trigger = document.getElementById('brew-trigger');
  const overlay = document.getElementById('brew-overlay');
  const cancelBtn = document.getElementById('brew-cancel');
  const copyBtn = document.getElementById('brew-copy');
  const copyIcon = document.getElementById('brew-copy-icon');
  const command = 'brew tap cai-layer/cai && brew install --cask cai';

  function openModal() {
    overlay?.classList.add('active');
  }

  function closeModal() {
    overlay?.classList.remove('active');
  }

  function copyCommand() {
    navigator.clipboard.writeText(command).then(() => {
      if (copyBtn) {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyBtn.textContent = 'Copy';
          closeModal();
        }, 1200);
      }
    });
  }

  trigger?.addEventListener('click', openModal);
  cancelBtn?.addEventListener('click', closeModal);
  copyBtn?.addEventListener('click', copyCommand);
  copyIcon?.addEventListener('click', copyCommand);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>

<style>
  .hero {
    background:
      radial-gradient(ellipse 1000px 1200px at 50% 40%, rgba(167, 139, 250, 0.15) 0%, rgba(196, 181, 253, 0.08) 30%, transparent 70%),
      radial-gradient(ellipse 900px 1100px at 50% 50%, rgba(255, 105, 180, 0.12) 0%, rgba(255, 140, 200, 0.06) 40%, transparent 75%),
      linear-gradient(180deg, #0A0A0A 0%, #111111 100%);
    padding: 12rem 0 4rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 10%;
    right: 10%;
    width: 900px;
    height: 900px;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.15) 0%, rgba(255, 140, 200, 0.08) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(120px);
    animation: float-up 12s ease-in-out infinite alternate;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 5%;
    left: 5%;
    width: 850px;
    height: 850px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.18) 0%, rgba(196, 181, 253, 0.1) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(120px);
    animation: float-up 15s ease-in-out infinite alternate-reverse;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    text-align: center;
    margin-bottom: 3.5rem;
    animation: float-up 0.8s ease-out;
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    color: #FFFFFF;
    margin-bottom: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .kbd {
    display: inline-block;
    padding: 0.05em 0.4em;
    margin: 0 0.05em;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    font-size: 0.82em;
    font-weight: 600;
    color: #FFFFFF;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-bottom-width: 2px;
    border-radius: 8px;
    vertical-align: middle;
    line-height: 1.2;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    color: #B0B0B0;
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    font-weight: 500;
  }

  .trust-badges {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #D0D0D0;
  }

  .trust-badge svg {
    width: 16px;
    height: 16px;
    color: #A78BFA;
    flex-shrink: 0;
  }

  .hero-quote {
    max-width: 520px;
    margin: 0 auto 2.5rem;
    padding: 0;
    border: none;
    text-align: center;
    font-style: italic;
    font-size: 0.95rem;
    color: #909090;
    line-height: 1.6;
  }

  .hero-quote cite {
    display: block;
    margin-top: 0.4rem;
    font-size: 0.8rem;
    color: #606060;
    font-style: normal;
  }

  .cta-row {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 1rem;
  }

  .ph-badge {
    display: block;
    transition: transform 0.3s ease;
  }

  .ph-badge:hover {
    transform: translateY(-3px);
  }

  .ph-badge img {
    display: block;
    height: 100%;
    width: auto;
  }

  .trust-badge-link {
    transition: border-color 0.2s ease, background 0.2s ease;
    cursor: pointer;
  }

  .trust-badge-link:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.1);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #FFFFFF;
    color: #1A1A1A;
    padding: 0.85rem 1.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2), 0 0 40px rgba(167, 139, 250, 0.15);
  }

  .cta-button:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3), 0 0 60px rgba(167, 139, 250, 0.25);
    background: #F5F5F5;
  }

  .apple-icon {
    width: 18px;
    height: 18px;
  }

  .version-row {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1rem;
    gap: 0;
  }

  .version-info {
    color: #C0C0C0;
    font-size: 0.85rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .version-info:hover {
    color: #FFFFFF;
  }

  .version-sep {
    color: #606060;
    font-size: 0.85rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  .brew-link {
    background: none;
    border: none;
    color: #C0C0C0;
    font-size: 0.85rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    letter-spacing: 0.02em;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s ease;
  }

  .brew-link:hover {
    color: #FFFFFF;
  }

  /* Homebrew modal */
  .brew-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .brew-modal-overlay.active {
    display: flex;
  }

  .brew-modal {
    background: #1A1A1A;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 2rem;
    max-width: 480px;
    width: calc(100% - 2rem);
    text-align: center;
    animation: scale-in 0.2s ease-out;
  }

  .brew-modal-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #FFFFFF;
    margin-bottom: 0.5rem;
  }

  .brew-modal-desc {
    font-size: 0.9rem;
    color: #909090;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .brew-command-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
  }

  .brew-command {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9rem;
    color: #E0E0E0;
    letter-spacing: 0.01em;
  }

  .brew-copy-icon {
    background: none;
    border: none;
    color: #909090;
    cursor: pointer;
    padding: 0.2rem;
    transition: color 0.2s ease;
    flex-shrink: 0;
  }

  .brew-copy-icon:hover {
    color: #FFFFFF;
  }

  .brew-modal-actions {
    display: flex;
    gap: 0.75rem;
  }

  .brew-btn {
    flex: 1;
    padding: 0.7rem 1.25rem;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .brew-btn-cancel {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #C0C0C0;
  }

  .brew-btn-cancel:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .brew-btn-copy {
    background: #FFFFFF;
    border: 1px solid #FFFFFF;
    color: #1A1A1A;
  }

  .brew-btn-copy:hover {
    background: #F0F0F0;
  }

  .cta-button:active {
    transform: translateY(-2px) scale(0.98);
  }

  .hero-demo {
    max-width: 920px;
    margin: 0 auto;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5), 0 10px 30px rgba(0, 0, 0, 0.3);
    animation: scale-in 0.8s ease-out 0.2s both;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hero-demo:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6), 0 15px 40px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .demo-video {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6rem 0 3rem;
      min-height: auto;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1.1rem;
    }

    .trust-badges {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .trust-badge {
      font-size: 0.8rem;
      padding: 0.4rem 0.75rem;
    }

    .cta-row {
      flex-direction: column;
      gap: 0.75rem;
    }

    .cta-button {
      padding: 1rem 2rem;
      font-size: 1rem;
    }

    .hero-demo {
      border-radius: 16px;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 1.85rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }
  }
</style>
