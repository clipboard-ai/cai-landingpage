---
import raycastLogo from '../assets/images/logo-raycast.png';
---

<section class="hero" id="hero">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">
        Meet Cai,<br />
        the private clipboard AI
      </h1>
      <p class="hero-subtitle">
        Select any text and run intelligent actions with ⌥C. <br /> 
        Runs 100% locally, powered by your favorite model.
      </p>

      <a href="https://raycast.com/store" class="cta-button" target="_blank" rel="noopener noreferrer">
        <img src={raycastLogo.src} alt="Raycast" class="button-logo" />
        <span>Download from Raycast</span>
      </a>
    </div>

    <div class="hero-demo">
      <video
        class="demo-video"
        autoplay
        loop
        muted
        playsinline
        poster="/videos/cai-hero-poster.webp"
        aria-label="Cai clipboard AI demo"
        data-lazy-video
      >
        <source src="/videos/cai-hero.mp4" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(ellipse 1000px 1200px at 50% 40%, rgba(167, 139, 250, 0.15) 0%, rgba(196, 181, 253, 0.08) 30%, transparent 70%),
      radial-gradient(ellipse 900px 1100px at 50% 50%, rgba(255, 105, 180, 0.12) 0%, rgba(255, 140, 200, 0.06) 40%, transparent 75%),
      linear-gradient(180deg, #0A0A0A 0%, #111111 100%);
    padding: 12rem 0 4rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 10%;
    right: 10%;
    width: 900px;
    height: 900px;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.15) 0%, rgba(255, 140, 200, 0.08) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(120px);
    animation: float-up 12s ease-in-out infinite alternate;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 5%;
    left: 5%;
    width: 850px;
    height: 850px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.18) 0%, rgba(196, 181, 253, 0.1) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(120px);
    animation: float-up 15s ease-in-out infinite alternate-reverse;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    text-align: center;
    margin-bottom: 3.5rem;
    animation: float-up 0.8s ease-out;
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    color: #FFFFFF;
    margin-bottom: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    color: #B0B0B0;
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    font-weight: 500;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #FFFFFF;
    color: #1A1A1A;
    padding: 0.85rem 1.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .cta-button:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    background: #F5F5F5;
  }

  .button-logo {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  .cta-button:active {
    transform: translateY(-2px) scale(0.98);
  }

  .hero-demo {
    max-width: 920px;
    margin: 0 auto;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5), 0 10px 30px rgba(0, 0, 0, 0.3);
    animation: scale-in 0.8s ease-out 0.2s both;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hero-demo:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6), 0 15px 40px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .demo-video {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6rem 0 3rem;
      min-height: auto;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1.1rem;
    }

    .cta-button {
      padding: 1rem 2rem;
      font-size: 1rem;
    }

    .hero-demo {
      border-radius: 16px;
    }
  }
</style>
