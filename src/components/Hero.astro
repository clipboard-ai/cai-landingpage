---

<section class="hero" id="hero">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">
        Meet Cai,<br />
        the <span class="highlight">private</span> clipboard AI
      </h1>
      <p class="hero-subtitle">
        Select any text and run intelligent actions with ⌥C.<br />
        No more app switching. Powered by your favorite model.
      </p>

      <div class="trust-badges">
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <span>100% Local</span>
        </div>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          <span>Open Source</span>
        </div>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          <span>Lightning Fast</span>
        </div>
      </div>

      <a href="https://github.com/clipboard-ai/cai/releases/download/v1.1.1/Cai-1.1.1-macos.dmg" class="cta-button" target="_blank" rel="noopener noreferrer">
        <svg class="apple-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" fill="currentColor"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
        <span>Download for Free</span>
      </a>
      <a href="https://github.com/clipboard-ai/cai/releases/latest" class="version-info" target="_blank" rel="noopener noreferrer">v1.1.1 &nbsp;|&nbsp; macOS</a>
    </div>

    <div class="hero-demo">
      <video
        class="demo-video"
        autoplay
        loop
        muted
        playsinline
        poster="/videos/cai-hero-poster.webp"
        aria-label="Cai clipboard AI demo"
        data-lazy-video
      >
        <source src="/videos/cai-hero.mp4" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(ellipse 1000px 1200px at 50% 40%, rgba(167, 139, 250, 0.15) 0%, rgba(196, 181, 253, 0.08) 30%, transparent 70%),
      radial-gradient(ellipse 900px 1100px at 50% 50%, rgba(255, 105, 180, 0.12) 0%, rgba(255, 140, 200, 0.06) 40%, transparent 75%),
      linear-gradient(180deg, #0A0A0A 0%, #111111 100%);
    padding: 12rem 0 4rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 10%;
    right: 10%;
    width: 900px;
    height: 900px;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.15) 0%, rgba(255, 140, 200, 0.08) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(120px);
    animation: float-up 12s ease-in-out infinite alternate;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 5%;
    left: 5%;
    width: 850px;
    height: 850px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.18) 0%, rgba(196, 181, 253, 0.1) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(120px);
    animation: float-up 15s ease-in-out infinite alternate-reverse;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    text-align: center;
    margin-bottom: 3.5rem;
    animation: float-up 0.8s ease-out;
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    color: #FFFFFF;
    margin-bottom: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    color: #B0B0B0;
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    font-weight: 500;
  }

  .trust-badges {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #D0D0D0;
  }

  .trust-badge svg {
    width: 16px;
    height: 16px;
    color: #A78BFA;
    flex-shrink: 0;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #FFFFFF;
    color: #1A1A1A;
    padding: 0.85rem 1.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2), 0 0 40px rgba(167, 139, 250, 0.15);
  }

  .cta-button:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3), 0 0 60px rgba(167, 139, 250, 0.25);
    background: #F5F5F5;
  }

  .apple-icon {
    width: 18px;
    height: 18px;
  }

  .version-info {
    display: block;
    margin-top: 1rem;
    text-align: center;
    color: #C0C0C0;
    font-size: 0.85rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .version-info:hover {
    color: #FFFFFF;
  }

  .cta-button:active {
    transform: translateY(-2px) scale(0.98);
  }

  .hero-demo {
    max-width: 920px;
    margin: 0 auto;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5), 0 10px 30px rgba(0, 0, 0, 0.3);
    animation: scale-in 0.8s ease-out 0.2s both;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hero-demo:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6), 0 15px 40px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .demo-video {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6rem 0 3rem;
      min-height: auto;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1.1rem;
    }

    .trust-badges {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .trust-badge {
      font-size: 0.8rem;
      padding: 0.4rem 0.75rem;
    }

    .cta-button {
      padding: 1rem 2rem;
      font-size: 1rem;
    }

    .hero-demo {
      border-radius: 16px;
    }
  }
</style>
