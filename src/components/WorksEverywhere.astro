---

<section class="works-everywhere">
  <div class="container">
    <h2 class="section-title">Works in <span class="highlight">any text field</span>, any app</h2>
    <p class="section-subtitle">
      Select some text, let Cai do the rest.<br />
      Use AI without switching apps.
    </p>

    <div class="app-grid">
      {apps.map((app, index) => (
        <div class="app-card" style={`animation-delay: ${index * 0.08}s`}>
          <div class="app-icon" set:html={app.icon} />
          <span class="app-name">{app.name}</span>
        </div>
      ))}
    </div>

    <a href="/docs/usage/context-snippets/" class="snippets-link">
      Power tip: teach Cai per-app context →
    </a>
  </div>
</section>

<style>
  .works-everywhere {
    padding: 7rem 0;
    background: #0E0E0E;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    text-align: center;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    text-align: center;
    color: #909090;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 640px;
    margin: 0 auto 4rem;
    line-height: 1.65;
  }

  .app-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .app-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 1.75rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: scale-in 0.4s ease-out both;
  }

  .app-card:hover {
    transform: translateY(-6px);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(167, 139, 250, 0.3);
    box-shadow: 0 12px 30px rgba(167, 139, 250, 0.15);
  }

  .app-icon {
    width: 32px;
    height: 32px;
    color: #C4B5FD;
    transition: color 0.3s ease;
  }

  .app-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .app-card:hover .app-icon {
    color: #F78595;
  }

  .app-name {
    color: #B0B0B0;
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .snippets-link {
    display: block;
    text-align: center;
    margin-top: 2.5rem;
    color: #909090;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .snippets-link:hover {
    color: var(--accent-light);
  }

  @media (max-width: 768px) {
    .works-everywhere {
      padding: 5rem 0;
    }

    .app-grid {
      gap: 1rem;
    }

    .app-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .app-card {
      padding: 1.25rem 1.25rem;
    }

    .app-icon {
      width: 28px;
      height: 28px;
    }

    .app-name {
      font-size: 0.75rem;
    }
  }
</style>
